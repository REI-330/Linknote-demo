# Optional runtime overrides for local development.
# Copy this file to `backend/.env` only if you want per-machine overrides.

# Local Whisper defaults
LINKNOTE_LOCAL_WHISPER_MODEL=small
LINKNOTE_WHISPER_DEVICE=cpu
LINKNOTE_WHISPER_COMPUTE_TYPE=int8

# Optional browser-cookie fallback
# LINKNOTE_USE_BROWSER_COOKIES=true

# Common API key examples
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
